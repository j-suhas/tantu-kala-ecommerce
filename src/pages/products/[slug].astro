---
import Base from '../../layouts/Base.astro';
import StockBadge from '../../components/StockBadge.astro';
import {
  products,
  productImage,
  productImageWebp,
  productOgImage,
  isBuyable,
  type Product,
} from '../../data/products';
import { inr } from '../../lib/format';
import { SITE } from '../../config/site.mjs';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

interface Props { product: Product; }
const { product } = Astro.props;
const buyable = isBuyable(product);

const availability =
  product.status === 'sold_out'
    ? 'https://schema.org/OutOfStock'
    : product.status === 'made_to_order'
    ? 'https://schema.org/PreOrder'
    : 'https://schema.org/InStock';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.shortDescription,
  image: new URL(productOgImage(product), SITE.url).href,
  brand: { '@type': 'Brand', name: SITE.name },
  offers: {
    '@type': 'Offer',
    priceCurrency: SITE.currency,
    price: product.price,
    availability,
    url: new URL(`/products/${product.slug}`, SITE.url).href,
  },
};
---
<Base
  title={product.name}
  description={product.shortDescription}
  ogImage={productOgImage(product)}
  jsonLd={jsonLd}
>
  <div class="wrap py-8">
    <a href="/" class="text-sm text-henna hover:underline">← All rakhis</a>

    <div class="mt-4 grid gap-8 md:grid-cols-2">
      <div class="card overflow-hidden">
        <picture>
          <source srcset={productImageWebp(product)} type="image/webp" />
          <img
            src={productImage(product)}
            alt={product.name}
            width="900" height="900"
            class="w-full aspect-square object-cover"
          />
        </picture>
      </div>

      <div>
        <StockBadge product={product} />
        <h1 class="mt-3 text-3xl sm:text-4xl">{product.name}</h1>
        <p class="mt-2 text-2xl font-semibold text-maroon">{inr(product.price)}</p>
        <p class="mt-4 text-ink/80 leading-relaxed">{product.description}</p>

        {buyable ? (
          <div class="mt-6 flex items-center gap-3">
            <label class="text-sm font-medium" for="qty">Qty</label>
            <input
              id="qty" type="number" min="1" value="1"
              class="w-20 rounded-lg border border-ink/20 px-3 py-2"
            />
            <button
              id="add-btn"
              class="btn-accent add-to-cart"
              data-slug={product.slug}
              data-name={product.name}
              data-price={product.price}
              data-qty="1"
            >Add to cart</button>
          </div>
        ) : (
          <p class="mt-6 rounded-xl bg-sand p-4 text-ink/70">
            This design is currently sold out. Message us on
            <a href={`https://wa.me/${SITE.whatsapp}`} class="text-henna font-semibold underline">WhatsApp</a>
            to ask about a restock.
          </p>
        )}

        {buyable && (
          <a href="/cart" class="mt-3 inline-block text-sm text-henna hover:underline">
            Go to cart & checkout →
          </a>
        )}

        <div class="mt-8 border-t border-ink/10 pt-5 text-sm text-ink/70 space-y-1">
          <p>✓ Handmade to order in pure cotton yarn</p>
          <p>✓ Secure UPI payment · confirmed by us before dispatch</p>
          <p>✓ Ships across India</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Keep the "Add to cart" qty in sync with the number input.
    const qty = document.getElementById('qty') as HTMLInputElement | null;
    const btn = document.getElementById('add-btn') as HTMLElement | null;
    qty?.addEventListener('input', () => {
      if (btn) btn.dataset.qty = String(Math.max(1, Number(qty.value) || 1));
    });
  </script>
</Base>
