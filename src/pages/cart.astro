---
import Base from '../layouts/Base.astro';
import DeliveryEstimate from '../components/DeliveryEstimate.astro';
import { SITE } from '../config/site.mjs';
---
<Base title="Your cart & checkout" description="Review your rakhis, share delivery details, and pay securely via UPI.">
  <div class="wrap py-8 max-w-2xl">
    <h1 class="text-3xl">Your order</h1>

    <!-- EMPTY -->
    <div id="empty" class="hidden mt-8 card p-8 text-center">
      <p class="text-ink/70">Your cart is empty.</p>
      <a href="/" class="btn-primary mt-4">Browse rakhis</a>
    </div>

    <!-- CART + CHECKOUT -->
    <div id="cart-section" class="hidden">
      <ul id="cart-items" class="mt-6 space-y-3"></ul>

      <div class="mt-4 card p-4 space-y-1 text-sm">
        <div class="flex justify-between"><span>Subtotal</span><span id="subtotal"></span></div>
        <div id="coupon-row" class="hidden flex justify-between text-leaf font-medium">
          <span id="coupon-label"></span><span id="coupon-amount"></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="flex items-center gap-2">
            Shipping
            <span id="free-ship-badge" class="hidden rounded-full bg-leaf/15 text-leaf px-2 py-0.5 text-xs font-semibold">Free shipping 🎉</span>
          </span>
          <span id="shipping"></span>
        </div>
        <div class="flex justify-between font-semibold text-maroon text-base pt-1 border-t border-ink/10 mt-1">
          <span>To pay via UPI</span><span id="total"></span>
        </div>
        <DeliveryEstimate class="pt-2" />
      </div>

      <form id="checkout-form" class="mt-6 card p-5 space-y-4" novalidate autocomplete="on">
        <h2 class="text-xl">Delivery details</h2>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium">Full name *</span>
            <input name="name" required autocomplete="name"
                   class="mt-1 w-full rounded-lg border border-ink/20 px-3 py-2" />
            <p id="err-name" role="alert" class="mt-1 text-sm text-henna hidden"></p>
          </label>
          <label class="block">
            <span class="text-sm font-medium">Phone (WhatsApp) *</span>
            <div class="mt-1 flex rounded-lg border border-ink/20 overflow-hidden focus-within:ring-2 focus-within:ring-saffron">
              <span class="px-3 py-2 bg-sand text-ink/70 select-none">+91</span>
              <input name="phone" required inputmode="numeric" maxlength="10" autocomplete="tel-national"
                     placeholder="10-digit mobile" class="flex-1 px-3 py-2 outline-none bg-transparent" />
            </div>
            <p id="err-phone" role="alert" class="mt-1 text-sm text-henna hidden"></p>
          </label>
        </div>

        <label class="block">
          <span class="text-sm font-medium">Delivery address *</span>
          <textarea name="address" required rows="3" autocomplete="street-address"
                    placeholder="Flat/house, street, area, city, state"
                    class="mt-1 w-full rounded-lg border border-ink/20 px-3 py-2"></textarea>
          <p id="err-address" role="alert" class="mt-1 text-sm text-henna hidden"></p>
        </label>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium">Pincode *</span>
            <input id="pincode" name="pincode" required inputmode="numeric" maxlength="6" autocomplete="postal-code"
                   class="mt-1 w-full rounded-lg border border-ink/20 px-3 py-2" />
            <p id="err-pincode" role="alert" class="mt-1 text-sm text-henna hidden"></p>
            <p id="pin-hint" class="mt-1 text-xs text-leaf hidden"></p>
          </label>
          <label class="block">
            <span class="text-sm font-medium">City / District *</span>
            <input id="city" name="city" required autocomplete="address-level2"
                   class="mt-1 w-full rounded-lg border border-ink/20 px-3 py-2" />
            <p id="err-city" role="alert" class="mt-1 text-sm text-henna hidden"></p>
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium">State</span>
            <input id="state" name="state" readonly autocomplete="address-level1"
                   placeholder="auto-filled from pincode"
                   class="mt-1 w-full rounded-lg border border-ink/20 px-3 py-2 bg-sand/40" />
          </label>
          <label class="block">
            <span class="text-sm font-medium">Note (optional)</span>
            <input name="note" class="mt-1 w-full rounded-lg border border-ink/20 px-3 py-2" />
          </label>
        </div>

        <!-- honeypot: humans never see or fill this; bots do -->
        <div class="hidden" aria-hidden="true">
          <label>Company <input name="company" tabindex="-1" autocomplete="off" /></label>
        </div>

        <button id="submit-btn" type="submit" class="btn-primary w-full">Place order & pay via UPI</button>
        <p class="text-xs text-ink/60 text-center">
          You'll get an order number, then pay securely by UPI. We verify payment and confirm shipping before dispatch.
        </p>
      </form>
    </div>

    <!-- PAYMENT -->
    <div id="pay-section" class="hidden mt-6">
      <div class="card p-6 text-center">
        <p class="text-leaf font-semibold">✓ Order placed</p>
        <h2 class="text-2xl mt-1">Pay <span id="pay-amount"></span> via UPI</h2>
        <p class="text-sm text-ink/60 mt-1">Order <span id="pay-ref" class="font-semibold text-ink"></span></p>
        <p class="text-sm text-ink/70 mt-1">Paying to <span class="font-semibold text-ink">{SITE.upi.payeeName}</span> — please confirm this name shows in your UPI app before paying.</p>
        <p class="mt-1 text-sm font-medium text-maroon">Please pay exactly <span id="pay-amount-2"></span></p>

        <a id="upi-btn" class="btn-accent w-full mt-5 hidden" href="#">Pay with any UPI app</a>

        <div id="upi-qr-wrap" class="mt-5 hidden">
          <p class="text-sm text-ink/70 mb-3">Scan with GPay / PhonePe / Paytm / any UPI app</p>
          <canvas id="upi-qr" class="mx-auto rounded-lg bg-white p-2"></canvas>
        </div>

        <div class="mt-4 text-sm">
          <p class="text-ink/70">UPI ID</p>
          <button id="copy-vpa" class="font-semibold text-maroon underline">{SITE.upi.vpa}</button>
          <span id="copied" class="ml-2 text-leaf hidden">copied ✓</span>
        </div>

        <DeliveryEstimate class="mt-4 justify-center text-center" />

        <div class="mt-5 rounded-xl bg-sand p-4 text-sm text-ink/80 text-left space-y-2">
          <p class="font-semibold text-maroon">After you pay:</p>
          <p>1. Keep the payment reference — we match it to order <span class="pay-ref-inline font-semibold"></span>.</p>
          <p>2. We verify the amount, confirm shipping, and dispatch your handmade order.</p>
        </div>

        <div class="mt-4 rounded-xl border border-leaf/30 bg-leaf/5 p-4 text-sm text-left">
          <p class="font-semibold text-ink">Optional — faster confirmation</p>
          <p class="text-ink/70 mt-1">Send your order on WhatsApp so we confirm and start processing right away. Not required — you can just pay above.</p>
          <a id="wa-confirm" class="btn-outline w-full mt-3" href="#" target="_blank" rel="noopener">
            Send order on WhatsApp
          </a>
        </div>

        <button id="new-order" class="block w-full mt-3 text-sm text-henna hover:underline">Start a new order</button>
      </div>
    </div>
  </div>

  <script>
    import '../scripts/checkout';
  </script>
</Base>
