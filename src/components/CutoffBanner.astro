---
import { SITE } from '../config/site.mjs';

const cutoff = new Date(SITE.orderCutoffISO);
const label = cutoff.toLocaleDateString('en-IN', { day: 'numeric', month: 'long' });
---

<div id="cutoff-banner" class="hidden bg-maroon text-cream text-center text-sm py-2 px-4">
  🪢 Raksha Bandhan is near — order by <strong>{label}</strong> to ship in time<span id="cutoff-days"></span>
</div>

<script define:vars={{ cutoffISO: SITE.orderCutoffISO }}>
  // Computed per-visitor at runtime so "X days left" is never stale.
  const banner = document.getElementById('cutoff-banner');
  const daysEl = document.getElementById('cutoff-days');
  const days = Math.ceil((new Date(cutoffISO).getTime() - Date.now()) / 86400000);
  if (banner && days > 0) {
    banner.classList.remove('hidden');
    if (days <= 21 && daysEl) daysEl.textContent = ` · just ${days} day${days === 1 ? '' : 's'} left`;
  }
</script>
