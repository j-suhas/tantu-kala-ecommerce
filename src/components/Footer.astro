---
import { SITE, NAV } from '../config/site.mjs';
const year = new Date().getFullYear();
const waHref = `https://wa.me/${SITE.whatsapp}`;
---

<footer class="mt-16 bg-maroon text-cream/90">
  <div class="wrap py-10 grid gap-8 sm:grid-cols-3">
    <div>
      <p class="font-display text-xl text-cream">{SITE.name}</p>
      <p class="mt-2 text-sm text-cream/70">{SITE.tagline}. Every piece handmade to order.</p>
    </div>

    <div class="text-sm">
      <p class="font-semibold text-cream mb-2">Explore</p>
      <ul class="space-y-1">
        {NAV.map((n) => (
          <li><a href={n.href} class="text-cream/80 hover:text-white">{n.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="text-sm">
      <p class="font-semibold text-cream mb-2">Reach us</p>
      <ul class="space-y-1">
        <li><a href={waHref} class="text-cream/80 hover:text-white">WhatsApp</a></li>
        <li><a href={SITE.instagram} class="text-cream/80 hover:text-white">Instagram</a></li>
        <li><a href={SITE.facebook} class="text-cream/80 hover:text-white">Facebook</a></li>
        <li><a href={`mailto:${SITE.email}`} class="text-cream/80 hover:text-white">{SITE.email}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-cream/15">
    <div class="wrap py-4 text-xs text-cream/60 flex flex-wrap gap-x-4 gap-y-1 justify-between">
      <span>© {year} {SITE.name}. Handmade in India.</span>
      <span>Secure UPI payment · No account needed</span>
    </div>
  </div>
</footer>
