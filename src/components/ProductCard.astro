---
import type { Product } from '../data/products';
import { productImage, productImageWebp, isBuyable } from '../data/products';
import { inr } from '../lib/format';
import StockBadge from './StockBadge.astro';

interface Props { product: Product; }
const { product } = Astro.props;
const href = `/products/${product.slug}`;
const buyable = isBuyable(product);
---
<article class={`card group ${!buyable ? 'opacity-80' : ''}`}>
  <a href={href} class="block relative aspect-square overflow-hidden bg-sand">
    <picture>
      <source srcset={productImageWebp(product)} type="image/webp" />
      <img
        src={productImage(product)}
        alt={product.name}
        loading="lazy"
        decoding="async"
        width="600" height="600"
        class="h-full w-full object-cover transition group-hover:scale-105"
      />
    </picture>
    <div class="absolute top-2 left-2"><StockBadge product={product} /></div>
  </a>
  <div class="p-4">
    <h3 class="font-display text-lg leading-tight">
      <a href={href} class="hover:text-henna">{product.name}</a>
    </h3>
    <p class="mt-1 text-sm text-ink/70 line-clamp-2">{product.shortDescription}</p>
    <div class="mt-3 flex items-center justify-between">
      <span class="font-semibold text-maroon text-lg">{inr(product.price)}</span>
      {buyable ? (
        <button
          class="btn-accent !px-4 !py-2 text-sm add-to-cart"
          data-slug={product.slug}
          data-name={product.name}
          data-price={product.price}
        >Add</button>
      ) : (
        <span class="text-sm text-ink/50 font-medium">Sold out</span>
      )}
    </div>
  </div>
</article>
